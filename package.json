{
  "name": "trmwrite",
  "version": "1.4.3",
  "description": "TrmWrite - 沉浸式长篇小说创作桌面工作台",
  "author": "TrmWrite",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:electron": "vite build && electron .",
    "build": "vue-tsc --noEmit && vite build",
    "build:win": "vite build && electron-builder --win --x64 --publish never",
    "publish:win": "vite build && electron-builder --win --x64 --publish never && powershell -ExecutionPolicy Bypass -File publish-release.ps1",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@tiptap/extension-character-count": "^2.6.6",
    "@tiptap/extension-placeholder": "^2.6.6",
    "@tiptap/pm": "^2.6.6",
    "@tiptap/starter-kit": "^2.6.6",
    "@tiptap/vue-3": "^2.6.6",
    "docx": "^8.5.0",
    "element-plus": "^2.7.6",
    "epub-gen-memory": "^1.1.0",
    "jsdom": "^24.1.0",
    "lowdb": "^7.0.1",
    "marked": "^13.0.2",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^3.2.1",
    "uuid": "^10.0.0",
    "vue": "^3.4.31",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.14.10",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^5.0.5",
    "electron": "^31.1.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.0.26"
  },
  "build": {
    "appId": "com.ainovelwriter.app",
    "icon": "build/icon.png",
    "productName": "TrmWrite",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "TrmWrite-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerLanguages": ["zh_CN", "en_US"],
      "language": "2052",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TrmWrite",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "TrmWrite-Setup-${version}.${ext}"
    }
  }
}
